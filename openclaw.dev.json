{
  "meta": {
    "description": "Development configuration for DAATAN"
  },
  "agents": {
    "defaults": {
      "workspace": "/home/mark/projects/daatan",
      "model": {
        "primary": "openrouter/google/gemini-2.0-flash-lite-001",
        "fallbacks": [
          "openrouter/meta-llama/llama-3.3-70b-instruct:free",
          "openrouter/free"
        ]
      }
    },
    "definitions": {
      "main": {
        "id": "main",
        "label": "Corvus (Dev)",
        "paths": {
          "base": "./agents/corvus"
        }
      },
      "devops": {
        "id": "devops",
        "label": "Infrastructure (Dev)",
        "paths": {
          "base": "./agents/devops"
        }
      },
      "qa": {
        "id": "qa",
        "label": "QA (Dev)",
        "paths": {
          "base": "./agents/qa"
        }
      }
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  },
  "auth": {
    "profiles": {
      "openrouter:default": {
        "provider": "openrouter",
        "mode": "api_key"
      }
    }
  }
}
