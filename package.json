{
  "name": "daatan",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:related": "vitest related --run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "DATABASE_URL=\"postgresql://daatan_test:daatan_test@localhost:5433/daatan_test\" vitest run --config vitest.config.integration.ts",
    "test:e2e": "playwright test",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "next lint --fix --file"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@aws-sdk/client-bedrock-agent": "^3.1000.0",
    "@aws-sdk/client-s3": "^3.1002.0",
    "@aws-sdk/client-ssm": "^3.1000.0",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@swc/helpers": "^0.5.18",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.564.0",
    "next": "15.5.12",
    "next-auth": "5.0.0-beta.25",
    "next-intl": "^4.8.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.1",
    "react-hot-toast": "^2.6.0",
    "resend": "^6.9.3",
    "rss-parser": "^3.13.0",
    "sharp": "^0.34.5",
    "tslib": "^2.8.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
