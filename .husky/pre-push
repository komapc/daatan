#!/bin/bash
# Pre-push hook: full typecheck + targeted test verification

set -e

echo "🚀 Running pre-push verification..."

# Set dummy environment variables for build/test (validation skipped via @t3-oss/env-nextjs)
export DATABASE_URL="postgresql://dummy:dummy@localhost:5432/dummy"
export NEXTAUTH_SECRET="dummy-secret-for-build-long-enough-32-chars-!!"
export NEXTAUTH_URL="http://localhost:3000"
export SKIP_ENV_VALIDATION=1

# 1. Type check (fast, clear errors)
echo "🔎 Running type check..."
if ! npm run typecheck; then
  echo "❌ Type check failed. Please fix type errors before pushing."
  exit 1
fi

# 2. Targeted test execution
# We only run tests related to changed files to keep the local loop fast.
# If no upstream is found or it's a new branch, we fall back to all tests.
echo "🧪 Running tests related to changes..."
STAGED_FILES=$(git diff --name-only origin/main...HEAD 2>/dev/null || echo "")

if [ -z "$STAGED_FILES" ]; then
  echo "   (No upstream changes found or origin/main missing, running all tests)"
  if ! npm test; then
    echo "❌ Tests failed. Please fix failing tests before pushing."
    exit 1
  fi
else
  if ! npm run test:related -- $STAGED_FILES; then
    echo "❌ Related tests failed. Please fix failing tests before pushing."
    exit 1
  fi
fi

# Check if auth-related files changed (informational warning, non-blocking)
AUTH_FILES_CHANGED=$(echo "$STAGED_FILES" | grep -E "(auth|session|login)" || true)

if [ -n "$AUTH_FILES_CHANGED" ]; then
  echo ""
  echo "⚠️  Authentication-related files changed:"
  echo "$AUTH_FILES_CHANGED"
  echo "  Please verify login flow locally before merging."
  echo ""
fi

echo "✅ Pre-push verification passed!"
