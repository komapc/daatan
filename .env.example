# Database
DATABASE_URL="postgresql://daatan:your_password@localhost:5432/daatan"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"  # Generate with: openssl rand -base64 32

# Google OAuth - Create at https://console.cloud.google.com/apis/credentials
# Add these to Authorized redirect URIs for each environment:
#   Staging:  https://staging.daatan.com/api/auth/callback/google
#   Prod:     https://daatan.com/api/auth/callback/google
# If sign-in works on staging but not prod (or vice versa), see docs/TROUBLESHOOTING-AUTH.md
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Web Search — all search requests go through Oracle (retro/api).
# Provider chain (DataForSEO, Serper, Brave, GDELT, etc.) is managed in Oracle, not here.
# See docs/SEARCH_PROVIDERS.md

# LLM Integration
GEMINI_API_KEY="your-gemini-api-key"

# Google Analytics 4 — measurement ID (not a secret; visible in client code)
# Create at https://analytics.google.com → Admin → Data Streams → Web
# docker-compose.prod/staging.yml maps _PROD/_STAGING → GA_MEASUREMENT_ID for the app container.
# IMPORTANT: enable Consent Mode modeling in the GA console per docs/ANALYTICS.md
# or declined users will generate zero data instead of modeled estimates.
GA_MEASUREMENT_ID="G-XZWVJM9KH4"
GA_MEASUREMENT_ID_PROD="G-XZWVJM9KH4"
GA_MEASUREMENT_ID_STAGING="G-Z4XXM7GYHW"

# Telegram channel notifications (optional — leave empty to disable)
# Bot: @ScoopPredictBot — token from @BotFather
# Channel: @ScoopPredict — must add bot as admin to the channel
# Both vars must be set on staging AND production servers
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_CLEAN_CHAT_ID=""  # optional — high-signal prod-only channel for key events/alarms

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
# Use the same key pair across environments so subscriptions persist
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# Resend — transactional email notifications (optional — leave empty to disable)
# Create API key at https://resend.com/api-keys
# EMAIL_FROM must match a verified domain in your Resend account
RESEND_API_KEY=""
EMAIL_FROM="Daatan <noreply@daatan.app>"

# Oracle API — TruthMachine probability estimates (optional — leave empty to disable)
# Generate API key with: openssl rand -hex 32
# Must match ORACLE_API_KEY set in oracle-api.service on the retro EC2
ORACLE_URL=https://oracle.daatan.com
ORACLE_API_KEY=

# IndexNow — instant Bing/Yandex indexing; key file must be at public/{key}.txt
INDEXNOW_KEY=711ada60e0032e070ede0e05de85a79e

# News-indexer integration (leave empty to keep feature off)
# NEWS_INDEXER_SECRET: inbound — news-indexer → Daatan push auth
# NEWS_INDEXER_URL + NEWS_INDEXER_API_KEY: outbound — Daatan → news-indexer resolve/match
NEWS_INDEXER_SECRET=
NEWS_INDEXER_URL=https://scrapper.daatan.com
NEWS_INDEXER_API_KEY=

TELEGRAM_DAATAN_BOT_TOKEN=""
TELEGRAM_CALENDAR_BOT_TOKEN=""
