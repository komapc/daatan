# NanoClaw + LiteLLM (Gemini) configuration
# Copy to .env and fill in your values

# --- LLM Backend ---
# Option A: Gemini (via LiteLLM sidecar - see docker-compose.yml)
GEMINI_API_KEY=your-gemini-api-key-here

# Option B: Direct Anthropic API (set ANTHROPIC_BASE_URL= to use Anthropic directly)
# ANTHROPIC_API_KEY=sk-ant-...

# Placeholder used by the credential proxy when routing through LiteLLM
ANTHROPIC_API_KEY=sk-placeholder
ANTHROPIC_BASE_URL=http://litellm:4000

NODE_ENV=production