{
  "$schema": "https://openclaw.ai/schema/v2.json",
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "none"
    },
    "trustedProxies": ["172.18.0.1", "127.0.0.1"]
  },
  "agents": {
    "defaults": {
      "workspace": "/workspace",
      "sandbox": {
        "mode": "non-main"
      },
      "model": {
        "primary": "openrouter/google/gemini-2.0-flash-lite-001",
        "fallbacks": [
          "openrouter/meta-llama/llama-3.3-70b-instruct:free",
          "openrouter/free"
        ]
      }
    },
    "list": [
      {
        "id": "daatan",
        "default": true,
        "name": "Corvus",
        "workspace": "/workspace/daatan",
        "identity": {
          "name": "Corvus",
          "theme": "DAATAN forecasting platform",
          "emoji": "🔮"
        },
        "skills": [
          "docker",
          "terraform",
          "github-actions",
          "nextjs",
          "daatan-deploy"
        ]
      },
      {
        "id": "calendar",
        "name": "Calendar Agent",
        "workspace": "/workspace/year-shape",
        "identity": {
          "name": "Calendar Agent",
          "theme": "YearWheel (Vite, TypeScript, Tailwind)",
          "emoji": "📅"
        },
        "skills": [
          "vite",
          "typescript",
          "cloudflare-pages",
          "tailwind"
        ]
      }
    ]
  },
  "models": {
    "providers": {
      "openrouter": {
        "apiKey": "${OPENROUTER_API_KEY}",
        "baseUrl": "https://openrouter.ai/api/v1",
        "api": "openai-completions",
        "models": [
          {
            "id": "google/gemini-2.0-flash-lite-001",
            "name": "Gemini 2.0 Flash Lite"
          },
          {
            "id": "meta-llama/llama-3.3-70b-instruct:free",
            "name": "Llama 3.3 70B Instruct (free)"
          },
          {
            "id": "free",
            "name": "Best Available Free Model"
          }
        ]
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "streamMode": "partial",
      "accounts": {
        "daatan": {
          "name": "Daatan",
          "botToken": "${TELEGRAM_BOT_TOKEN_DAATAN}"
        }
      }
    }
  },
  "browser": {
    "enabled": true,
    "headless": true
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  },
  "auth": {
    "profiles": {
      "openrouter:default": {
        "provider": "openrouter",
        "mode": "api_key"
      }
    }
  }
}
