# Copy to terraform.tfvars and fill in values.
# terraform.tfvars is gitignored — never commit it.

aws_region        = "eu-central-1"
ec2_instance_type = "t3.large"    # 2 vCPU, 8 GB, ~$60/mo | ARM cheaper: t4g.large ~$52/mo
ssh_key_name      = "daatan-key"

# Your IP for SSH access (use /32 for single IP). Get with: curl -s ifconfig.me
allowed_ssh_cidr = "YOUR_IP/32"

# LiteLLM proxy auth key (OpenClaw → LiteLLM). Change from default.
litellm_master_key = "sk-change-me"
